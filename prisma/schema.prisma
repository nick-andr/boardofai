generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String?
  summary   String?  // Running conversation summary for model context
  prompts   Prompt[]

  /// Canonical ordered list of model ids used for this conversation (e.g. ["openai","anthropic",...])
  modelIds         String?
  /// Models that have failed in this conversation and should no longer be called.
  disabledModelIds String?

  /// Parent/child relationship for nested conversations.
  /// Top-level "board" conversations have parentId = null and modelId = null.
  parentId   String?
  parent     Conversation?  @relation("ConversationParent", fields: [parentId], references: [id])
  children   Conversation[] @relation("ConversationParent")

  /// For 1:1 child conversations, the bound model id (e.g. "openai", "anthropic").
  modelId    String?

  @@map("conversations")
}

model Prompt {
  id             String          @id @default(cuid())
  conversationId String
  content        String
  modelCount     Int
  createdAt      DateTime        @default(now())
  responses      ModelResponse[]
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summary        Summary?
  viewpoints     Viewpoint[]

  @@map("prompts")
}

model ModelResponse {
  id          String     @id @default(cuid())
  promptId    String
  modelId     String
  modelName   String
  content     String
  status      String     @default("pending")
  error       String?
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  viewpointId String?
  prompt      Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  viewpoint   Viewpoint? @relation(fields: [viewpointId], references: [id])

  @@map("model_responses")
}

model Viewpoint {
  id          String          @id @default(cuid())
  promptId    String
  title       String
  description String
  createdAt   DateTime        @default(now())
  responses   ModelResponse[]
  prompt      Prompt          @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@map("viewpoints")
}

model Summary {
  id        String   @id @default(cuid())
  promptId  String   @unique
  content   String
  createdAt DateTime @default(now())
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@map("summaries")
}

model ModelCatalog {
  id          String   @id @default(cuid())
  modelId     String   @unique
  name        String
  provider    String
  enabled     Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("model_catalog")
}
